# Day 09 Lab — Environment Variables
# Copy file này thành .env và điền giá trị thật:
#   cp .env.example .env

# ─── LLM / synthesis ───
# Bắt buộc nếu muốn chạy synthesis qua Groq API.
GROQ_API_KEY=
LLM_MODEL=llama-3.1-8b-instant

# ─── Optional embeddings / retrieval provider ───
# Chỉ cần điền nếu muốn bật OpenAI embeddings cho retrieval.
OPENAI_API_KEY=

# ─── ChromaDB / retrieval ───
CHROMA_DB_PATH=./chroma_db
CHROMA_COLLECTION=day09_docs
RETRIEVAL_TOP_K=3

# ─── MCP (Sprint 3) ───
MCP_SERVER_URL=http://127.0.0.1:8080
# Modes: http | real | hybrid | mock-only
MCP_SERVER_MODE=http
MCP_ALLOW_SIDE_EFFECTS=false

# ─── Trace / eval ───
TRACE_OUTPUT_DIR=./artifacts/traces
